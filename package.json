{
  "private": true,
  "type": "module",
  "scripts": {
    "dev:js": "node bin/build.js --dev",
    "dev:css": "npx @tailwindcss/cli -i ./resources/css/notify.css -o ./public/dist/notify.css --watch",
    "build:js": "node bin/build.js",
    "build:css": "npx @tailwindcss/cli -i ./resources/css/notify.css -o ./public/dist/notify.css --minify",
    "dev": "npm-run-all --parallel dev:*",
    "build": "npm-run-all build:*"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.10",
    "alpinejs": "^3.12.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.18"
  }
}
